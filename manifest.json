{
  "name": "SumberYAML Clean Responsive Reddit Routing Patch",
  "version": "2026.06.06-1",
  "description": "Simplifies OpenClash groups/rules, routes marketplace/social/banking via input VMess load-balance, and creates Reddit-specific routing from input node names containing reddit.",
  "files": [
    ".github/workflows/update-openclash.yml",
    "scripts/apply_openclash_clean_responsive_rules.py",
    "scripts/validate_openclash_outputs.py",
    "scripts/assert_latest_openclash_outputs.py",
    "scripts/force_output_update_marker.py",
    "README_CLEAN_RESPONSIVE_REDDIT_PATCH.md",
    "install_patch.sh"
  ],
  "openclash_policy": {
    "direct_reject_selector_only": true,
    "drop_proxy_types": ["ss", "ssr"],
    "no_risky_group_keys": ["lazy", "timeout"],
    "reddit_input_node_name_keyword": "reddit",
    "input_vmess_loadbalance_group": "INPUT-VMESS-LB"
  }
}
