  "files": [
    ".github/workflows/update-openclash.yml",
    "scripts/apply_openclash_service_score_groups.py",
    "scripts/fetch_extra_sources_alive.py",
    "scripts/apply_openclash_game_block_inline_safe.py",
    "scripts/validate_game_block_inline_safe.py",
    "scripts/validate_openclash_outputs.py",
    "scripts/assert_latest_openclash_outputs.py",
    "scripts/force_output_update_marker.py",
    "input/extra_sources_urls.txt",
    "README_SERVICE_SCORE_BLIBLI_LINKS_ONLY_PATCH.md"
